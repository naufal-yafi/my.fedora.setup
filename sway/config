# Default config for sway
# Copy this to ~/.config/sway/config and edit it to your liking.
font pango:FiraCode Nerd Font Mono 11

### Autoload
exec_always waybar
exec_always nm-applet
exec_always gammastep -O 4500 &
exec_always --no-startup-id blueman-applet
exec_always swaybg -i ~/.config/sway/background/wp-ghibli-style.jpg -m fill

output * adaptive_sync on

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term foot
set $rofi_cmd rofi \
        -terminal '$term'
set $menu $rofi_cmd -show combi -combi-modes drun -theme ~/.config/rofi/themes/rounded-gray-dark.rasi #run -modes combi

### Idle configuration
exec swayidle -w \
 timeout 300 'swaylock -f' \
 timeout 600 'systemctl suspend' \

### Configuration Files
include ~/.config/sway/.config.d/style.conf
include ~/.config/sway/.config.d/run-apps.conf
include ~/.config/sway/.config.d/keybindings.conf
include ~/.config/sway/.config.d/windows-feel.conf
