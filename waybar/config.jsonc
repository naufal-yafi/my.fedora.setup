{
    "layer": "top",
    "position": "top",
    
    "height": 10,
    "width": 1890,
    "margin-top": 10,

    "modules-left": [
        "custom/logo",
        "sway/workspaces",
        "sway/mode", 
        "sway/window" 
    ],
    "modules-center": [ "clock" ],
    "modules-right": [
        "memory",
        "temperature",
        "backlight",
        "battery",
        "pulseaudio", 
        "tray",
        "custom/ollama",
        "custom/virtualkeyboard",
        "custom/nightlight",
        "custom/power"
    ],

    // ---- Global module configuration ----

        // ---- Left Modules ----
            "custom/logo": {
                "format": "Óüô",
                "tooltip-format": "fedora sway",
                "on-click": "rofi -show combi -combi-modes drun -theme ~/.config/rofi/themes/rounded-gray-dark.rasi"
            },

            "sway/workspaces": {
                "format": "{name}{icon}",
                "format-icons": {
                    "10": " | ůįíí ",
		            "focused": " - - - Ôí≥ ",
                    "default": ""
                }
            },

            "sway/mode": {
                "format": "<span style=\"italic\">{}</span>"
            },

            "sway/window": {
                "format": "Óėā {title}",
                "max-length": 40
            },
        // ---- Left Modules ----

        // ---- Center Modules ----
            "clock": {
                "interval": 1,
                "format": "ÔÄó  {:%H.%M}",
                "format-alt": "Ó™į  {:%d %b %Y, %H.%M}",
                "tooltip-format": "<tt><small>{calendar}</small></tt>",
                "calendar": {
                    "mode": "monthly",
                    "mode-mon-col": 3,
                    "weeks-pos": "right",
                    "on-scroll": 1,
                    "format": {
                        "months": "<span color='#ffead3'><b>{}</b></span>",
                        "days": "<span color='#ecc6d9'><b>{}</b></span>",
                        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
                    }
                }
            },
        // ---- Center Modules ----

        // ---- Right Modules ----
            "memory": {
                "format": "Óįô {used:0.1f}G"
            },

            "temperature": {
                // "thermal-zone": 2,
                // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
                "critical-threshold": 68,
                "format-critical": "ÔĀĪ  {temperatureC}¬įC {icon}",
                "format": "{temperatureC}¬įC {icon}",
                "format-icons": ["ÔĚę", "ÔčČ", "ÔĚ©"]
            },

            "backlight": {
                "format": "{percent}% {icon}",
                "format-icons": ["ůĪ©é", "ůĪ©ź", "ůĪ©í", "ůĪ©Ē", "ůĪ©Ė"]
            },
            
            "battery": {
                "states": {
                    "good": 80,
                    "warning": 45,
                    "critical": 20
                },
                "format": "{capacity}% {icon}",
                "format-full": "{capacity}% {icon}",
                "format-charging": "{capacity}% Ôá¶",
                "format-plugged": "{capacity}% Ôá¶",
                "format-icons": ["ÔČĄ", "ÔČÉ", "ÔČā", "ÔČĀ", "ÔČÄ"]
            },
            "battery#bat2": {
                "bat": "BAT2"
            },

            "pulseaudio": {
                "format": "{volume}% {icon} ",
                "format-bluetooth": "{volume}% {icon}ÔäĒ",
                "format-muted": "ůįĚü",
                "format-icons": {
                    // "alsa_output.pci-0000_00_1f.3.analog-stereo": "ÓĆ≠",
                    // "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "ÓĽ®ÓĆ≠",
                    "headphone": "ÔÄ•",
                    "hands-free": "ÔĖź",
                    "headset": "ÔĖź",
                    "phone": "Ôāē",
                    "phone-muted": "Óīó",
                    "portable": "Ôāē",
                    "car": "ÔÜĻ",
                    "default": ["ÔÄß", "ÔÄ®"]
                },
                "scroll-step": 1,
                "on-click": "pavucontrol",
                "ignored-sinks": ["Easy Effects Sink"]
            },

            "tray": {
                "icon-size": 21,
                "spacing": 10
                // "icons": {
                //   "blueman": "bluetooth"
                // }
            },

            "custom/ollama": {
                "format": "{}",
                "exec": "~/.config/waybar/scripts/ollama/status.sh",
                "on-click": "~/.config/waybar/scripts/ollama/toggle.sh",
                "interval": 2
            },

            "custom/virtualkeyboard": {
                "format": "{}",
                "exec": "~/.config/waybar/scripts/virtual-keyboard/status.sh",
                "on-click": "~/.config/waybar/scripts/virtual-keyboard/toggle.sh",
                "interval": 2
            },

            "custom/power": {
                "format": "ÔÄĎ ",
                "tooltip": false,
                "on-click": "shutdown now"
            },
            "custom/nightlight": {
                "format": "{}",
                "exec": "~/.config/waybar/scripts/nightlight/status.sh",
                "on-click": "~/.config/waybar/scripts/nightlight/toggle.sh",
                "interval": 2
            }
        // ---- Right Modules ----
        
    // ---- Global module configuration ----
}
